# Copy this file to .env and fill in your values

# Google OAuth (credentials.json and token.json handle auth — see execution/ scripts)
# No API key needed for Sheets/Slides if using OAuth

# Slack (required for process_challenge.py Slack invite/reactivation)
# SLACK_USER_TOKEN: xoxp- user OAuth token with scopes: admin, users:read, users:read.email
# See directives/process_challenge.md for setup instructions.
SLACK_USER_TOKEN=xoxp-your-token-here
SLACK_ADMIN_EMAIL=admin@sealuw.example.com
SLACK_ADMIN_PASSWORD=your-admin-password-here

# Add other API keys below as the system grows
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# APOLLO_API_KEY=
# HUNTER_API_KEY=
